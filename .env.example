# ---------- Database ----------
MONGODB_URI="mongodb+srv://<user>:<pass>@cluster.xxxxx.mongodb.net/blog?retryWrites=true&w=majority"
MONGODB_DB="blog"

# ---------- Auth (NextAuth v5) ----------
# openssl rand -base64 32
AUTH_SECRET=""
# Chỉ cần trên Vercel; local dev để trống
AUTH_URL=""
AUTH_TRUST_HOST=true

# Google OAuth — https://console.cloud.google.com → OAuth 2.0 Client IDs
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Email magic link qua Resend
AUTH_RESEND_KEY=""
AUTH_EMAIL_FROM="Blog <noreply@yourdomain.com>"

# ---------- AI (Phase 3) ----------
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
FIRECRAWL_API_KEY=""

# ---------- Storage (Phase 2) ----------
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="blog-media"
R2_PUBLIC_URL="https://pub-xxxxx.r2.dev"

# ---------- Redis (Phase 3) ----------
REDIS_URL="rediss://default:xxx@xxx.upstash.io:6379"

# ---------- Security ----------
# openssl rand -hex 32 → 64 ký tự hex cho AES-256
ENCRYPTION_KEY=""
# random string để bảo vệ endpoint /api/cron/*
CRON_SECRET=""
